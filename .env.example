# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_read_token
SANITY_API_WRITE_TOKEN=your_write_token

# Resend Email API
RESEND_API_KEY=your_resend_api_key
# From address — set to verified domain (e.g. noreply@takiev.bg). Defaults to onboarding@resend.dev (free tier).
RESEND_FROM_EMAIL=noreply@takiev.bg

# Groq AI (for /novini page — news summarization + future blog summaries)
# Free tier: 14 400 заявки/ден. Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://takiev.bg
CONTACT_EMAIL=office@takiev.bg
